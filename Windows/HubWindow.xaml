<Window x:Class="DesktopImagePin.Windows.HubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Image Pin"
        Width="720"
        Height="480"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="Desktop Image Pin" />
            <TextBlock Margin="0,4,0,14"
                       Foreground="#666666"
                       Text="Ctrl + Shift + H: Toggle Hub   Ctrl + Wheel: Width   Alt + Wheel: Height" />
            <Border Margin="0,0,0,12"
                    Padding="10"
                    Background="#F3F6FA"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock HorizontalAlignment="Center"
                           Foreground="#526173"
                           Text="Drag and drop images here (multiple files supported)" />
            </Border>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="110"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="AddImageButton_Click"
                    Content="Add Images" />
            <Button Width="130"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="DuplicateSelectedButton_Click"
                    Content="Duplicate" />
            <Button Width="90"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="RemoveAllButton_Click"
                    Content="Remove All" />
            <Button Width="90"
                    Height="34"
                    Click="ExitButton_Click"
                    Content="Exit" />
        </StackPanel>

        <GroupBox Header="Displayed Images">
            <ListBox x:Name="ImagesListBox"
                     ItemsSource="{Binding Items}"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,3"
                                Padding="10"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="0" />
                                    <ColumnDefinition Width="154" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="72" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="#777777"
                                               Text="{Binding FilePath}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="11"
                                               Foreground="#777777"
                                               Text="{Binding DisplayLayerText}" />
                                    <StackPanel Margin="0,3,0,0"
                                                Orientation="Horizontal">
                                        <Button Width="46"
                                                Height="26"
                                                Margin="0,0,3,0"
                                                Tag="{Binding}"
                                                Click="SetTopmostButton_Click"
                                                Content="Top" />
                                        <Button Width="46"
                                                Height="26"
                                                Margin="0,0,3,0"
                                                Tag="{Binding}"
                                                Click="SetNormalLayerButton_Click"
                                                Content="Normal" />
                                        <Button Width="46"
                                                Height="26"
                                                Tag="{Binding}"
                                                Click="SetBottommostButton_Click"
                                                Content="Back" />
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Width="72"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        Tag="{Binding}"
                                        Click="ChangeImageButton_Click"
                                        Content="Change" />
                                <Button Grid.Column="3"
                                        Width="72"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        Tag="{Binding}"
                                        Click="RemoveImageButton_Click"
                                        Content="Remove" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </DockPanel>
</Window>
