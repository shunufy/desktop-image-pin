<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>DesktopImagePin</AssemblyName>
    <RootNamespace>DesktopImagePin</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>shunufy</Authors>
    <Description>Pin transparent, movable images directly onto the Windows desktop.</Description>
    <RepositoryUrl>https://github.com/shunufy/desktop-image-pin</RepositoryUrl>
  </PropertyGroup>

</Project>
